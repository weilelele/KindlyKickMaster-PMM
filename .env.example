# ── Feishu App Credentials ───────────────────────────────────────
# From open.feishu.cn → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From 事件订阅 → 请求网址验证
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=                        # 留空即不加密

# ── Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# ── Supabase ─────────────────────────────────────────────────────
# 用 service_role key（不是 anon key），有完整读写权限
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ── Bot Config ───────────────────────────────────────────────────
# 你自己的飞书 open_id（发私聊给 bot 时有管理员权限）
OWNER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 需要 bot 定时播报的群 chat_id
# 在群里发消息后，从事件 payload 的 event.message.chat_id 获取
GROUP_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot 自身的 open_id（用于识别群里的 @bot）
# 可从飞书开放平台 → 应用信息 → 机器人 获取，或调用 /auth/v3/app_access_token 后用 bot.info 接口
BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
